{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Docent",
  "version": "2.12.20",
  "identifier": "com.gitlayton.agentforge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Docent",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true
      },
      {
        "label": "glow",
        "url": "/?window=glow",
        "title": "Glow",
        "width": 800,
        "height": 600,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https:; connect-src ipc: http://ipc.localhost; font-src 'self' data: asset:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/llama-server"
    ],
    "resources": [
      "../scripts/forge-relay.mjs",
      "bin/llama-libs/*"
    ],
    "macOS": {
      "signingIdentity": null,
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/git-layton/docent-releases/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxMDkwQUZBM0VCNzJBMEEKUldRS0tyYysrZ29KZ1QyT1RMNjVPekowWm04YnNuZ0hjMytwYm5XZE9jUkNvSEp4UWFFYzNLUWYK"
    }
  }
}
