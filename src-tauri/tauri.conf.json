{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Forge",
  "version": "2.0.0",
  "identifier": "com.gitlayton.agentforge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Agent Forge",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https:; connect-src ipc: http://ipc.localhost; font-src 'self' data: asset:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/llama-server"
    ],
    "resources": [
      "../scripts/forge-relay.mjs"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/git-layton/agent-forge/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM0NjlENzE0OTVFNUY1NTIKUldSUzllV1ZGTmRweEcrM0dyYUNMUzJHOHN2emZYVDFjREpNcFpmL0g5VUhxN0tiSGZsVzRYZ3MK"
    }
  }
}
